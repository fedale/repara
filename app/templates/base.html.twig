<!DOCTYPE html>
<html data-bs-theme="dark">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
        {# Run `composer require symfony/webpack-encore-bundle` to start using Symfony UX #}
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
            {{ encore_entry_link_tags('gridview') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}

        <style>
            /* Native (JS-free) dropdown groups for the header nav. */
            .nav-group { position: relative; }
            .nav-group > summary {
                list-style: none;
                cursor: pointer;
                padding: .25rem .5rem;
                border-radius: .25rem;
            }
            .nav-group > summary::-webkit-details-marker { display: none; }
            .nav-group > summary::after { content: " ▾"; opacity: .6; }
            .nav-group[open] > summary { background: var(--bs-secondary-bg); }
            .nav-group__menu {
                position: absolute;
                top: 100%;
                left: 0;
                z-index: 1000;
                min-width: 12rem;
                margin-top: .25rem;
                padding: .25rem;
                background: var(--bs-body-bg);
                border: 1px solid var(--bs-border-color);
                border-radius: .375rem;
                box-shadow: 0 .5rem 1rem rgba(0,0,0,.15);
            }
            .nav-group__menu a { display: block; padding: .35rem .6rem; border-radius: .25rem; white-space: nowrap; }
            .nav-group__menu a:hover { background: var(--bs-secondary-bg); }
            .sidebar-group { margin-bottom: .75rem; }
            .sidebar-group__title {
                font-size: .7rem;
                text-transform: uppercase;
                letter-spacing: .05em;
                opacity: .6;
                padding: .25rem .25rem 0;
            }
        </style>
    </head>
    <body>
        {# Single source of truth for the gridview navigation, reused by the
           header dropdowns and the sidebar sections. #}
        {% set menu = [
            { title: 'Progetti', items: [
                { route: 'gridview_project_index', label: 'Progetti' },
                { route: 'gridview_project_task_index', label: 'Attività' },
                { route: 'gridview_project_task_item_index', label: 'Voci attività' },
                { route: 'gridview_project_milestone_index', label: 'Milestone' },
                { route: 'gridview_project_task_template_index', label: 'Template attività' },
                { route: 'gridview_project_task_item_template_index', label: 'Voci template' },
            ] },
            { title: 'Asset', items: [
                { route: 'gridview_asset_index', label: 'Asset' },
                { route: 'gridview_asset_type_index', label: 'Tipi' },
                { route: 'gridview_asset_brand_index', label: 'Marche' },
                { route: 'gridview_asset_model_index', label: 'Modelli' },
                { route: 'gridview_asset_category_index', label: 'Categorie' },
                { route: 'gridview_asset_attachment_index', label: 'Allegati' },
            ] },
            { title: 'Clienti', items: [
                { route: 'gridview_customer_index', label: 'Clienti' },
                { route: 'gridview_customer_type_index', label: 'Tipi cliente' },
                { route: 'gridview_customer_location_index', label: 'Sedi' },
                { route: 'gridview_customer_location_place_index', label: 'Locali' },
                { route: 'gridview_customer_location_place_asset_index', label: 'Asset installati' },
                { route: 'gridview_customer_location_place_asset_attachment_index', label: 'Allegati asset' },
            ] },
            { title: 'Utenti', items: [
                { route: 'gridview_user_index', label: 'Utenti' },
                { route: 'gridview_user_type_index', label: 'Tipi utente' },
                { route: 'gridview_user_role_index', label: 'Ruoli' },
                { route: 'gridview_user_group_index', label: 'Gruppi' },
            ] },
            { title: 'Sistema', items: [
                { route: 'gridview_website_index', label: 'Siti' },
                { route: 'gridview_access_control_index', label: 'Controllo accessi' },
                { route: 'app_setting_index', label: 'Impostazioni' },
            ] },
        ] %}
        <div class="page">
            <header class="navbar navbar-expand-md d-print-none">
                <div class="container-xl">
                    <a class="navbar-brand" href="{{ path('gridview_customer_index') }}">⚫️ Repara</a>
                    <nav class="navbar-nav flex-row gap-2 me-auto">
                        {% for group in menu %}
                            <details class="nav-group nav-item">
                                <summary class="nav-link">{{ group.title }}</summary>
                                <div class="nav-group__menu">
                                    {% for item in group.items %}
                                        <a class="nav-link" href="{{ path(item.route) }}">{{ item.label }}</a>
                                    {% endfor %}
                                </div>
                            </details>
                        {% endfor %}
                    </nav>
                    <div class="navbar-nav flex-row align-items-center gap-2">
                        {# Host-page language switcher: drives the gridview instantly via
                           the gridview-locale-switcher controller (window.GridviewI18n).
                           A single switcher for the whole page — no per-grid switcher. #}
                        <button class="btn btn-sm btn-outline-secondary"
                                data-controller="gridview-locale-switcher"
                                data-action="click->gridview-locale-switcher#toggle">
                            🌐 <span data-gridview-locale-switcher-target="label">EN</span>
                        </button>
                        <button class="btn btn-sm btn-outline-secondary"
                                data-controller="color-theme"
                                data-action="click->color-theme#toggle">
                            <span data-color-theme-target="icon">☀</span>
                        </button>
                    </div>
                </div>
            </header>

            {% set sidebar_content %}{% block sidebar %}{% endblock %}{% endset %}
            <div class="page-wrapper">
                <div class="page-body">
                    <div class="container-xl">
                        <div class="row g-3">
                            {% if sidebar_content|trim is not empty %}
                                <aside class="col-12 col-md-3 page-sidebar">
                                    {{ sidebar_content }}
                                </aside>
                            {% endif %}
                            <main class="col">
                                {% block body %}{% endblock %}
                            </main>
                        </div>
                    </div>
                </div>

                <footer class="footer footer-transparent d-print-none">
                    <div class="container-xl text-center">
                        {% block footer %}
                            <span class="text-secondary">© {{ "now"|date("Y") }} Repara</span>
                        {% endblock %}
                    </div>
                </footer>
            </div>
        </div>
    </body>
</html>
