{#
  Inline cell editor: a single-field form (built from the column's control, so it
  reuses validation incl. NotBlank/UniqueEntity). Save with the OK button / Enter
  / blur / change; Escape or ✕ cancels. Submitted via the gridview-inline-edit
  controller.
#}
{{ form_start(form, {'action': action, 'attr': {'class': 'gv-inline-form', 'data-action': 'submit->gridview-inline-edit#submit'}}) }}
    <div class="gv-inline-field">
        {{ form_widget(attribute(form, field), {'attr': {
            'data-gridview-inline-edit-target': 'input',
            'data-action': 'keydown->gridview-inline-edit#key',
        }}) }}
        <button type="submit" class="gv-btn gv-btn-primary gv-inline-ok" title="Conferma">OK</button>
        <button type="button" class="gv-btn gv-inline-cancel" title="Annulla"
                data-action="gridview-inline-edit#cancel">✕</button>
    </div>
    {{ form_errors(attribute(form, field)) }}
{{ form_end(form) }}
