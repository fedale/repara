{
    "name": "fedale/gridview-bundle",
    "description": "Gridview in Yii2 style inside your Symfony projects",
    "type": "symfony-bundle",
    "require": {
        "php": ">=7.4",
        "symfony/framework-bundle": "^6.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "doctrine/orm": "^2.12",
        "symfony/form": "6.4.*",
        "twig/twig": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Fedale\\GridviewBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fedale\\GridviewBundle\\Tests\\": "tests/"
        }
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Danilo Di Moia",
            "email": "zitter@gmail.com"
        }
    ]
}
