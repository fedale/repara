{#
  Form wrapper for generated CRUD forms.

  - Custom layout: `body` is the user view (crud.form.view) already rendered with
    its `{ attribute }` tokens replaced by the matching widget HTML. The control
    fields are therefore already rendered on the shared FormView; form_end() only
    emits the remainder (CSRF, submit, any unplaced field).
  - Automatic layout: `body` is null, so form_start()/form_end() render every
    field in declaration order (Symfony's default row layout).

  `action` is the submit URL; `formAttr` carries Stimulus/Turbo hooks from the handler.
#}
{% set validate = validate|default(null) %}
{% set crudAttr = formAttr|default({})|merge({
    'data-action': 'submit->gridview-crud#submit',
    'class': ('gv-crud-form ' ~ formAttr.class|default(''))|trim,
}) %}
{% if validate %}
{% set crudAttr = crudAttr|merge({
    'data-controller': 'gridview-form-validate',
    'data-gridview-form-validate-check-url-value': validate.checkUrl,
    'data-gridview-form-validate-unique-value': validate.unique|json_encode,
    'data-gridview-form-validate-id-value': validate.id|default(''),
    'data-gridview-form-validate-name-value': validate.formName|default('gridform'),
}) %}
{% endif %}
{{ form_start(form, {'action': action|default(''), 'attr': crudAttr}) }}
    {% if body is defined and body is not null %}
        {{ body|raw }}
    {% endif %}
{{ form_end(form) }}
