{#
  Delete confirmation recap shown in the CRUD modal. `rows` is a list of
  {label, value} from GridCrudHandler::renderDeleteConfirm(); the POST form to
  `action` carries the CSRF token and is submitted via the gridview-crud controller.
#}
<div class="gv-delete-confirm">
    <p class="mb-3">{{ 'crud.delete_confirm'|trans({}, 'GridviewBundle') }}</p>

    {% if rows is not empty %}
    <dl class="row mb-3">
        {% for row in rows %}
        <dt class="col-sm-4 text-muted">{{ row.label }}</dt>
        <dd class="col-sm-8">{{ row.value }}</dd>
        {% endfor %}
    </dl>
    {% endif %}

    <form method="post" action="{{ action }}" data-action="submit->gridview-crud#submit">
        <input type="hidden" name="_token" value="{{ token }}">
        <div class="d-flex justify-content-end gap-2">
            <button type="button" class="gv-btn" data-bs-dismiss="modal">{{ 'crud.cancel'|trans({}, 'GridviewBundle') }}</button>
            <button type="submit" class="gv-btn gv-btn-danger">{{ 'crud.delete'|trans({}, 'GridviewBundle') }}</button>
        </div>
    </form>
</div>
